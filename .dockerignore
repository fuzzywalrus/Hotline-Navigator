# Keep the Docker build context small. The Linux build (Dockerfile.linux-build)
# does `COPY . .` then builds fresh inside the container, so none of these are
# needed — and copying them (esp. Rust target/, ~19GB locally) fills the VM disk.

# Rust build output (rebuilt inside the container)
**/target/

# Node deps (reinstalled via `npm ci` inside the container)
**/node_modules/

# Frontend build output (regenerated by `tauri build`)
hotline-tauri/dist/

# Local build outputs / release staging
linux-*-output/
release/
**/*.dmg
**/*.AppImage

# VCS + editor + OS cruft
.git/
.github/
**/.DS_Store

# Mobile gen dirs (not used by the Linux build)
hotline-tauri/src-tauri/gen/android/
hotline-tauri/src-tauri/gen/apple/
